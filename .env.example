# Copy this file to ".env" and fill in the real values (that .env is git-ignored).
# Set the same variables in Cloudflare Pages → Settings → Variables and Secrets
# so the published /impressum page shows them. Leave blank and the page shows
# clearly-marked [placeholders] instead.
IMPRESSUM_NAME=
IMPRESSUM_STREET=
IMPRESSUM_CITY=
IMPRESSUM_COUNTRY=
IMPRESSUM_EMAIL=
